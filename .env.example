# DSN GlitchTip — à renseigner après le premier lancement
# (créer un projet dans GlitchTip puis copier son DSN)
NUXT_PUBLIC_SENTRY_DSN=[CHANGE_ME]

# GlitchTip
GLITCHTIP_SECRET_KEY=replace-with-openssl-rand-hex-32
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_DOMAIN=http://glitchtip.localhost:3000
GLITCHTIP_CSRF_TRUSTED_ORIGINS=http://glitchtip.localhost:3000
GLITCHTIP_DEFAULT_FROM_EMAIL=errors@localhost

# Umami
UMAMI_APP_SECRET=replace-with-openssl-rand-hex-16

# Bases de données
GLITCHTIP_DB_NAME=glitchtip
GLITCHTIP_DB_USER=glitchtip_user
GLITCHTIP_DB_PASSWORD=replace-with-a-strong-password
UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami_user
UMAMI_DB_PASSWORD=replace-with-a-strong-password

# Website ID Umami — à renseigner après le premier lancement
# (créer le site dans Umami puis copier son Website ID)
NUXT_PUBLIC_UMAMI_WEBSITE_ID=[CHANGE_ME]
NUXT_PUBLIC_UMAMI_SCRIPT_URL=http://localhost:3000/umami/script.js
